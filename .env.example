# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# --- Anthropic API -----------------------------------------------------------
# Required for the LLM commentary step (Prompt 8 / `make commentary LIVE=1`).
# Obtain at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- FRED API ----------------------------------------------------------------
# Required for macro-regularised forecasting (Prompt 6 / `make forecast`).
# Free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- SEC EDGAR User-Agent ----------------------------------------------------
# Required by SEC fair-use policy for all EDGAR data fetches.
# SEC validates that the User-Agent contains a real email address — a GitHub
# handle alone will return 403.  Use an alias to avoid exposing your primary
# email, e.g.:
#   yourname+sec@gmail.com
#   yourname@users.noreply.github.com  (GitHub's privacy-preserving address)
# NEVER commit your primary personal email to git history.
SEC_USER_AGENT=ai-financial-analyst-portfolio/1.0 yourname+sec@gmail.com
